# Shared env for local development. Copy to `.env.local` (gitignored) and fill in real values.
# Consumed by the Cloudflare Worker apps (apps/cheffing-hub, apps/joescreen-download) via wrangler,
# which reads CLOUDFLARE_* from the process environment.

# Cloudflare account + API token for `wrangler deploy` / `wrangler r2 ...`.
# Token scopes needed: Workers Scripts:Edit, Account Settings:Read, Workers R2 Storage:Edit.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
