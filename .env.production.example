# Production env. Copy to `.env.production` (gitignored) and fill in real values.
# Used for production `wrangler deploy --env production` to cheffing.dev. In CI these come from repo
# secrets (CLOUDFLARE_API_TOKEN / CLOUDFLARE_ACCOUNT_ID) instead of this file.

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
