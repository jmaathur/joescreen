.DS_Store
build/
build-ios/
.build/
DerivedData/
*.xcuserstate
xcuserdata/

# The Xcode project is GENERATED from Apps/project.yml (which IS committed). Regenerate with:
#   xcodegen generate --spec Apps/project.yml
Apps/*.xcodeproj/
# XcodeGen also generates the Info.plist from project.yml's `info:` blocks — the committed
# source-of-truth is project.yml, not the emitted plist, so ignore the generated plists to avoid
# drift. The entitlements files ARE hand-written and committed.
Apps/macOS/Resources/Info-macOS.plist
Apps/iOS/Resources/Info-iOS.plist
.swiftpm/xcode/package.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
.env
TEAM_ID.local

# harness internal
.claude/
