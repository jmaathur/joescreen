# TestFlight / App Store Connect credentials for the ship scripts.
# Copy to `.env.testflight` (gitignored) and fill in real values. Never commit the real file
# or the .p8 key. See docs/SHIPPING_TESTFLIGHT.md for how to obtain each value.

# Your 10-character Apple Developer Team ID (Membership page in the developer account).
APPLE_TEAM_ID=ABCDE12345

# App Store Connect API key — create at App Store Connect → Users and Access → Integrations →
# App Store Connect API. Give it "App Manager" access. You get a Key ID, an Issuer ID (UUID),
# and a one-time .p8 download.
ASC_API_KEY_ID=XXXXXXXXXX
ASC_API_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Path to the downloaded AuthKey_<KEYID>.p8. Absolute, or relative to the repo root.
# Keep the key OUTSIDE the repo or in a gitignored location (e.g. ~/.appstoreconnect/).
ASC_API_KEY_PATH=/Users/you/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
