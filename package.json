{
	"name": "joescreen-monorepo",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"dev": "bash scripts/dev.sh",
		"livekit": "bash scripts/livekit.sh",
		"app": "bash scripts/app.sh",
		"build": "turbo run build",
		"test": "turbo run test",
		"clean": "turbo run clean",
		"build:ipa": "bash scripts/build-ipa.sh",
		"testflight": "bash scripts/testflight.sh",
		"testflight:submit": "bash scripts/testflight-submit.sh",
		"ship:setup": "bash scripts/testflight-setup.sh",
		"asc:provision": "bash -c 'set -a; . ./.env.testflight; set +a; bun scripts/asc-provision.mjs \"$@\"' --",
		"asc:create-app": "bash scripts/asc-create-app.sh",
		"testflight:review": "bash -c 'set -a; . ./.env.testflight; set +a; bun scripts/asc-testflight-review.mjs \"$@\"' --"
	},
	"workspaces": [
		"apps/*"
	],
	"packageManager": "bun@1.3.14",
	"devDependencies": {
		"turbo": "^2.5.3"
	}
}
